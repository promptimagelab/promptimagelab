# Redirect rules for promptimagelab.com
# 1) Make /index.html permanently redirect to /
# 2) Redirect clean paths (e.g. /about) to their .html equivalent when that file exists

RewriteEngine On
RewriteBase /

# 1) /index.html -> /
Redirect 301 /index.html /

# 2) If request has no extension and corresponding .html exists, redirect to it
# Skip requests that already map to an existing file
RewriteCond %{REQUEST_URI} !\.[^/]+$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
RewriteRule ^(.*?)/?$ /$1.html [R=301,L]

# End of .htaccess
